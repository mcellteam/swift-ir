#!/bin/bash
# Lightweight TACC launch script for alignEM using uv
# Usage: source tacc_launch

echo "Loading modules for software OpenGL rendering..."
module purge
ml intel/19.1.1
ml swr/21.2.5
ml impi/19.0.9
ml fftw3/3.3.10

echo "Setting environment variables..."
export QT_API=pyside6
export QT_QUICK_BACKEND=software
export QSG_RHI_BACKEND=opengl
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1

# The SWR module sets SWR_LD_LIBRARY_PATH (not LD_LIBRARY_PATH).
# Chromium's GPU process needs Mesa's GL/EGL libs in LD_LIBRARY_PATH.
if [ -n "$TACC_SWR_LIB" ]; then
    export LD_LIBRARY_PATH="${TACC_SWR_LIB}:${TACC_SWR_DIR}/lib64:${LD_LIBRARY_PATH:-}"
fi

# Ensure ~/.local/lib is in LD_LIBRARY_PATH (for locally installed libs below)
export LD_LIBRARY_PATH="$HOME/.local/lib:${LD_LIBRARY_PATH:-}"

# Tell libglvnd's EGL dispatch where to find Mesa's EGL vendor implementation.
# libglvnd uses JSON ICD files to locate vendor .so's. Since we install RPMs
# without system paths, we create the ICD file manually.
_EGL_VENDOR_DIR="$HOME/.local/share/glvnd/egl_vendor.d"
if [ ! -f "$_EGL_VENDOR_DIR/50_mesa.json" ]; then
    mkdir -p "$_EGL_VENDOR_DIR"
    cat > "$_EGL_VENDOR_DIR/50_mesa.json" <<'EJSON'
{
    "file_format_version" : "1.0.0",
    "ICD" : {
        "library_path" : "libEGL_mesa.so.0"
    }
}
EJSON
fi
export __EGL_VENDOR_LIBRARY_FILENAMES="$_EGL_VENDOR_DIR/50_mesa.json"

# ---------- Auto-install missing libraries into ~/.local/lib ----------
_LOCAL_LIB="$HOME/.local/lib"
mkdir -p "$_LOCAL_LIB"

# Helper: extract .so files from an RPM into ~/.local/lib
_install_rpm() {
    local url="$1" label="$2"
    echo "Installing ${label}..."
    local _tmpdir=$(mktemp -d)
    (
        cd "$_tmpdir" &&
        curl -sLO "$url" &&
        rpm2cpio *.rpm | cpio -idm 2>/dev/null &&
        find . -name "*.so*" -exec cp -n {} "$_LOCAL_LIB/" \;
    )
    rm -rf "$_tmpdir"
}

# 1. libxcb-cursor.so.0 — required by Qt6 xcb platform plugin (not in RHEL8)
if ! ldconfig -p 2>/dev/null | grep -q libxcb-cursor && [ ! -f "$_LOCAL_LIB/libxcb-cursor.so.0" ]; then
    _install_rpm \
        "https://dl.rockylinux.org/pub/rocky/9/AppStream/x86_64/os/Packages/x/xcb-util-cursor-0.1.4-3.el9.x86_64.rpm" \
        "libxcb-cursor (Qt6 xcb plugin)"
fi

# 2. libEGL.so.1 — EGL dispatch library (from libglvnd, NOT mesa-libEGL)
if [ ! -f "$_LOCAL_LIB/libEGL.so.1" ] && ! ldconfig -p 2>/dev/null | grep -q "libEGL.so.1"; then
    _install_rpm \
        "https://dl.rockylinux.org/pub/rocky/8/AppStream/x86_64/os/Packages/l/libglvnd-egl-1.3.4-2.el8.x86_64.rpm" \
        "libglvnd-egl (EGL dispatch)"
fi

# 3. libEGL_mesa.so.0 — Mesa EGL vendor implementation (used by libglvnd EGL dispatch)
if [ ! -f "$_LOCAL_LIB/libEGL_mesa.so.0" ] && ! ldconfig -p 2>/dev/null | grep -q "libEGL_mesa.so.0"; then
    _install_rpm \
        "https://dl.rockylinux.org/pub/rocky/8/AppStream/x86_64/os/Packages/m/mesa-libEGL-23.1.4-4.el8_10.x86_64.rpm" \
        "mesa-libEGL (EGL vendor impl)"
fi

# 4. libGLdispatch.so.0 — GL dispatch library (dependency of libEGL.so.1)
if [ ! -f "$_LOCAL_LIB/libGLdispatch.so.0" ] && ! ldconfig -p 2>/dev/null | grep -q "libGLdispatch.so.0"; then
    _install_rpm \
        "https://dl.rockylinux.org/pub/rocky/8/AppStream/x86_64/os/Packages/l/libglvnd-1.3.4-2.el8.x86_64.rpm" \
        "libglvnd (GL dispatch)"
fi

# 5. libgbm.so.1 — buffer management (required by Mesa EGL to create displays)
if [ ! -f "$_LOCAL_LIB/libgbm.so.1" ] && ! ldconfig -p 2>/dev/null | grep -q "libgbm.so.1"; then
    _install_rpm \
        "https://dl.rockylinux.org/pub/rocky/8/AppStream/x86_64/os/Packages/m/mesa-libgbm-23.1.4-4.el8_10.x86_64.rpm" \
        "mesa-libgbm (EGL buffer mgmt)"
fi

# 6. libdrm.so.2 — DRM library (dependency of libgbm)
if [ ! -f "$_LOCAL_LIB/libdrm.so.2" ] && ! ldconfig -p 2>/dev/null | grep -q "libdrm.so.2"; then
    _install_rpm \
        "https://dl.rockylinux.org/pub/rocky/8/AppStream/x86_64/os/Packages/l/libdrm-2.4.115-2.el8.x86_64.rpm" \
        "libdrm (DRM library)"
fi

# 7. swrast_dri.so — Mesa software rasterizer DRI driver (required by Mesa EGL)
if [ ! -f "$_LOCAL_LIB/swrast_dri.so" ] && [ ! -f "/usr/lib64/dri/swrast_dri.so" ]; then
    _install_rpm \
        "https://dl.rockylinux.org/pub/rocky/8/AppStream/x86_64/os/Packages/m/mesa-dri-drivers-23.1.4-4.el8_10.x86_64.rpm" \
        "mesa-dri-drivers (software rasterizer)"
fi

# Tell Mesa where to find DRI drivers (swrast_dri.so) since they're not in /usr/lib64/dri/
export LIBGL_DRIVERS_PATH="$_LOCAL_LIB:/usr/lib64/dri${LIBGL_DRIVERS_PATH:+:$LIBGL_DRIVERS_PATH}"
# Force software rendering (no hardware GPU on TACC compute nodes)
export LIBGL_ALWAYS_SOFTWARE=1

# ---------- EGL surfaceless override for VNC (no X11 DRI) ----------
# Qt WebEngine's Chromium calls eglGetPlatformDisplay(EGL_PLATFORM_X11, ...),
# which fails on VNC because Xvnc has no DRI support. We confirmed that
# eglGetPlatformDisplay(EGL_PLATFORM_SURFACELESS_MESA, ...) works with
# swrast_dri.so. This LD_PRELOAD wrapper redirects all EGL platform
# display requests to use surfaceless instead.
_EGL_OVERRIDE="$HOME/.local/lib/egl_surfaceless.so"
rm -f "$_EGL_OVERRIDE"  # Force recompile (updated source)
if [ ! -f "$_EGL_OVERRIDE" ]; then
    echo "Compiling EGL surfaceless override..."
    _src=$(mktemp /tmp/egl_surfaceless.XXXXXX.c)
    cat > "$_src" << 'CSRC'
/* EGL surfaceless override for TACC VNC (no X11 DRI support).
 *
 * Chromium loads EGL via dlopen/dlsym, which bypasses normal LD_PRELOAD
 * symbol interposition. We must intercept dlsym() itself so that when
 * Chromium calls dlsym(handle, "eglGetPlatformDisplay"), it gets our
 * wrapper that forces EGL_PLATFORM_SURFACELESS_MESA.
 */
#define _GNU_SOURCE
#include <dlfcn.h>
#include <string.h>
#include <stdint.h>

typedef void* EGLDisplay;
typedef unsigned int EGLenum;
typedef intptr_t EGLAttrib;
#define EGL_PLATFORM_SURFACELESS_MESA 0x31DD

extern void *__libc_dlsym(void *, const char *);

static EGLDisplay my_eglGetPlatformDisplay(EGLenum platform,
        void *native_display, const EGLAttrib *attrib_list) {
    typedef EGLDisplay (*fn_t)(EGLenum, void*, const EGLAttrib*);
    void *egl = dlopen("libEGL.so.1", RTLD_LAZY | RTLD_NOLOAD);
    if (!egl) egl = dlopen("libEGL.so.1", RTLD_LAZY);
    fn_t real_fn = (fn_t)__libc_dlsym(egl, "eglGetPlatformDisplay");
    return real_fn(EGL_PLATFORM_SURFACELESS_MESA, (void*)0, (void*)0);
}

static EGLDisplay my_eglGetDisplay(void *display_id) {
    return my_eglGetPlatformDisplay(0, (void*)0, (void*)0);
}

/* Intercept dlsym: redirect EGL display function lookups to our wrappers */
void *dlsym(void *handle, const char *name) {
    if (name) {
        if (strcmp(name, "eglGetPlatformDisplay") == 0)
            return (void*)my_eglGetPlatformDisplay;
        if (strcmp(name, "eglGetDisplay") == 0)
            return (void*)my_eglGetDisplay;
    }
    return __libc_dlsym(handle, name);
}
CSRC
    gcc -shared -fPIC -o "$_EGL_OVERRIDE" "$_src" -ldl 2>/dev/null && \
        echo "EGL override compiled OK" || \
        echo "WARNING: Failed to compile EGL override (gcc not available?)"
    rm -f "$_src"
fi
if [ -f "$_EGL_OVERRIDE" ]; then
    export LD_PRELOAD="${_EGL_OVERRIDE}${LD_PRELOAD:+:$LD_PRELOAD}"
fi
# Force Qt to use GLX (not EGL) so the override only affects Chromium
export QT_XCB_GL_INTEGRATION=xcb_glx

# Verify critical libraries
_missing=""
[ ! -f "$_LOCAL_LIB/libxcb-cursor.so.0" ] && ! ldconfig -p 2>/dev/null | grep -q libxcb-cursor && _missing="$_missing libxcb-cursor.so.0"
[ ! -f "$_LOCAL_LIB/libEGL.so.1" ] && ! ldconfig -p 2>/dev/null | grep -q "libEGL.so.1" && _missing="$_missing libEGL.so.1"
[ ! -f "$_LOCAL_LIB/libgbm.so.1" ] && ! ldconfig -p 2>/dev/null | grep -q "libgbm.so.1" && _missing="$_missing libgbm.so.1"
[ ! -f "$_LOCAL_LIB/swrast_dri.so" ] && [ ! -f "/usr/lib64/dri/swrast_dri.so" ] && _missing="$_missing swrast_dri.so"
if [ -n "$_missing" ]; then
    echo "WARNING: Missing libraries:$_missing"
    echo "WebGL may not work. Check network access to dl.rockylinux.org."
fi
unset _LOCAL_LIB _missing

echo "Launching alignEM via uv..."
uv run alignEM.py "$@"
