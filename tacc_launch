#!/bin/bash
# Lightweight TACC launch script for alignEM using uv
# Usage: source tacc_launch

echo "Loading modules for software OpenGL rendering..."
module purge
ml intel/19.1.1
ml swr/21.2.5
ml impi/19.0.9
ml fftw3/3.3.10

echo "Setting environment variables..."
export QT_API=pyside6
export QT_QUICK_BACKEND=software
export QSG_RHI_BACKEND=opengl
export OMP_NUM_THREADS=1
export MKL_NUM_THREADS=1

# The SWR module sets SWR_LD_LIBRARY_PATH (not LD_LIBRARY_PATH).
# Chromium's GPU process needs Mesa's GL/EGL libs in LD_LIBRARY_PATH.
if [ -n "$TACC_SWR_LIB" ]; then
    export LD_LIBRARY_PATH="${TACC_SWR_LIB}:${TACC_SWR_DIR}/lib64:${LD_LIBRARY_PATH:-}"
fi

# Ensure ~/.local/lib is in LD_LIBRARY_PATH (for locally installed libs below)
export LD_LIBRARY_PATH="$HOME/.local/lib:${LD_LIBRARY_PATH:-}"

# ---------- Auto-install missing libraries into ~/.local/lib ----------
_LOCAL_LIB="$HOME/.local/lib"
mkdir -p "$_LOCAL_LIB"

# Helper: extract .so files from an RPM into ~/.local/lib
_install_rpm() {
    local url="$1" label="$2"
    echo "Installing ${label}..."
    local _tmpdir=$(mktemp -d)
    (
        cd "$_tmpdir" &&
        curl -sLO "$url" &&
        rpm2cpio *.rpm | cpio -idm 2>/dev/null &&
        find . -name "*.so*" -exec cp -n {} "$_LOCAL_LIB/" \;
    )
    rm -rf "$_tmpdir"
}

# 1. libxcb-cursor.so.0 — required by Qt6 xcb platform plugin (not in RHEL8)
if ! ldconfig -p 2>/dev/null | grep -q libxcb-cursor && [ ! -f "$_LOCAL_LIB/libxcb-cursor.so.0" ]; then
    _install_rpm \
        "https://dl.rockylinux.org/pub/rocky/9/AppStream/x86_64/os/Packages/x/xcb-util-cursor-0.1.4-3.el9.x86_64.rpm" \
        "libxcb-cursor (Qt6 xcb plugin)"
fi

# 2. libEGL.so.1 — required by Chromium ANGLE for WebGL (TACC SWR has no EGL)
if [ ! -f "$_LOCAL_LIB/libEGL.so.1" ] && ! ldconfig -p 2>/dev/null | grep -q "libEGL.so.1"; then
    _install_rpm \
        "https://dl.rockylinux.org/pub/rocky/8/AppStream/x86_64/os/Packages/m/mesa-libEGL-23.1.4-4.el8_10.x86_64.rpm" \
        "mesa-libEGL (WebGL/ANGLE)"
fi

# 3. libGLdispatch.so.0 / libOpenGL.so.0 — EGL dependency
if [ ! -f "$_LOCAL_LIB/libGLdispatch.so.0" ] && ! ldconfig -p 2>/dev/null | grep -q "libGLdispatch.so.0"; then
    _install_rpm \
        "https://dl.rockylinux.org/pub/rocky/8/AppStream/x86_64/os/Packages/m/mesa-libGL-23.1.4-4.el8_10.x86_64.rpm" \
        "mesa-libGL (EGL dependency)"
fi

# Verify critical libraries
_missing=""
[ ! -f "$_LOCAL_LIB/libxcb-cursor.so.0" ] && ! ldconfig -p 2>/dev/null | grep -q libxcb-cursor && _missing="$_missing libxcb-cursor.so.0"
[ ! -f "$_LOCAL_LIB/libEGL.so.1" ] && ! ldconfig -p 2>/dev/null | grep -q "libEGL.so.1" && _missing="$_missing libEGL.so.1"
if [ -n "$_missing" ]; then
    echo "WARNING: Missing libraries:$_missing"
    echo "WebGL may not work. Check network access to dl.rockylinux.org."
fi
unset _LOCAL_LIB _missing

echo "Launching alignEM via uv..."
uv run alignEM.py "$@"
